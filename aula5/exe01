/*Escreva um programa que declare e inicialize duas variáveis inteiras x e y. Em 
seguida, você deve exibir o conteúdo dessas variáveis e seus respectivos 
endereços.*/

#include <iostream>
using namespace std;
int main() {
    //declaração e inicialização das variaveis inteiras
    int x = 15;
    int y = 34;

    //exibição do conteudo 
    cout << " Conteudo das variaveis " << endl;
    cout << " Valor de x: " << x << endl;
    cout << " Valor de y: " << y << endl;

    //usando o operador & pra exibir o endereço d memória 
    cout << " Endereço de memória " << endl;
    cout << " Endereço de memória de x: " << &x << endl;
    cout << " Endereço de memória de y: " << &y << endl;

    return 0;



}
  
